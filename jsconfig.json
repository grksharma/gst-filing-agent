{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "checkJs": false,
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": false,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "App.js", "__tests__/**/*"],
  "exclude": ["node_modules"]
}
